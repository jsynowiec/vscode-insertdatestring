{
  "name": "vscode-insertdatestring",
  "displayName": "Insert Date & Time",
  "description": "Insert dates, times, ISO 8601 strings, Unix timestamps, and custom Day.js-formatted timestamps in VS Code — with shortcuts, timezone support, and configurable formats.",
  "version": "3.1.8",
  "publisher": "jsynowiec",
  "homepage": "https://github.com/jsynowiec/vscode-insertdatestring#readme",
  "bugs": {
    "url": "https://github.com/jsynowiec/vscode-insertdatestring/issues"
  },
  "license": "MIT",
  "author": "Jakub Synowiec",
  "main": "./dist/extension.js",
  "activationEvents": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/jsynowiec/vscode-insertdatestring"
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "prettier": "prettier --write 'src/*.{ts,json,md,yml,js,mjs}'",
    "fmtcheck": "prettier --check 'src/*.{ts,json,md,yml,js,mjs}'",
    "test": "tsx --test src/__tests__/*.test.ts",
    "package": "node esbuild.mjs --production",
    "prepackage": "npm run typecheck && npm run lint && npm run fmtcheck",
    "prebuild": "npm run typecheck && npm run lint && npm run fmtcheck"
  },
  "dependencies": {
    "dayjs": "^1.11.20"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.101.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.2"
  },
  "engines": {
    "vscode": "^1.101.0",
    "node": ">=22"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "keywords": [
    "date",
    "time",
    "datetime",
    "timestamp",
    "unix timestamp",
    "epoch",
    "epoch timestamp",
    "iso 8601",
    "iso8601",
    "current date",
    "current time",
    "insert date",
    "insert time",
    "insert timestamp",
    "date formatter",
    "date formatting",
    "time formatting",
    "custom date format",
    "timezone",
    "iana timezone",
    "utc",
    "dayjs",
    "markdown",
    "front matter",
    "changelog",
    "logging",
    "snippets",
    "keyboard shortcut",
    "date string",
    "timestamp generator"
  ],
  "contributes": {
    "commands": [
      {
        "command": "insertDateString.insertDateTime",
        "title": "Insert DateTime"
      },
      {
        "command": "insertDateString.insertDate",
        "title": "Insert Date"
      },
      {
        "command": "insertDateString.insertTime",
        "title": "Insert Time"
      },
      {
        "command": "insertDateString.insertTimestamp",
        "title": "Insert Timestamp"
      },
      {
        "command": "insertDateString.insertOwnFormatDateTime",
        "title": "Insert Formatted DateTime"
      },
      {
        "command": "insertDateString.resetWorkspaceFormat",
        "title": "Reset Workspace DateTime Format Override"
      }
    ],
    "configuration": {
      "title": "Insert Date String Configuration",
      "properties": {
        "insertDateString.format": {
          "type": "string",
          "default": "YYYY-MM-DD HH:mm:ss",
          "description": "Date time format to be used."
        },
        "insertDateString.formatDate": {
          "type": "string",
          "default": "YYYY-MM-DD",
          "description": "Date format to be used."
        },
        "insertDateString.formatTime": {
          "type": "string",
          "default": "HH:mm:ss",
          "description": "Time format to be used."
        },
        "insertDateString.timezone": {
          "type": "string",
          "default": "",
          "description": "IANA timezone name (e.g. 'America/New_York', 'Europe/Warsaw', 'UTC'). Leave empty to use local system time."
        }
      }
    },
    "keybindings": [
      {
        "command": "insertDateString.insertDateTime",
        "key": "shift+ctrl+i",
        "mac": "shift+cmd+i",
        "when": "editorTextFocus"
      },
      {
        "command": "insertDateString.insertOwnFormatDateTime",
        "key": "shift+ctrl+alt+i",
        "mac": "shift+cmd+alt+i",
        "when": "editorTextFocus"
      }
    ]
  },
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#005696",
    "theme": "dark"
  }
}
